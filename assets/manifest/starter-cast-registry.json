  "registryVersion": "2026-03-21",
  "issue": 69,
  "dependsOn": [114],
  "sourceMapRegistry": "packages/contracts/world-map-registry.sample.json",
  "keyConventions": {
    "characterId": "char.<city>.<dagLocationSlot>.<name>",
    "bundleId": "bundle.character.<characterId>",
    "packId": "pack.<city>.<mapLocationId>.starter",
    "rewardBundleId": "reward.<city>.<mapLocationId>.<rewardType>",
    "assetKeyPrefix": "character.<city>.<dagLocationSlot>.<name>",
    "slotRosterId": "slot.<city>.<dagLocationSlot>.starter"
  },
  "assetBundleContract": {
    "requiredOutputs": [
      {
        "logicalAssetType": "portrait.default",
        "usage": "dialogue-avatar",
        "notes": "Primary circular or card avatar for dialogue rail, session lists, and roster cards."
      },
      {
        "logicalAssetType": "sprite.default",
        "usage": "hangout-presence",
        "notes": "Default full-body or half-body scene sprite used when no emotion-specific pose is available."
      },
      {
        "logicalAssetType": "scene.default",
        "usage": "learn-hangout-still",
        "notes": "Static fallback still for runtime-assets when animation or layered compositing is unavailable."
      },
      {
        "logicalAssetType": "voice.reference",
        "usage": "game-engine-tone-anchor",
        "notes": "Text-only persona/voice reference JSON or markdown used by creative-assets and game-engine prompt packs."
      }
    ],
    "optionalOutputs": [
      {
        "logicalAssetType": "sprite.expression-set",
        "usage": "emotion-variants",
        "notes": "Optional expression or pose set keyed by emotion labels such as neutral, cheerful, shy, and focused."
      },
      {
        "logicalAssetType": "intro.video",
        "usage": "scene-intro-cinematic",
        "notes": "Optional first-meet clip for higher-fidelity city packs."
      },
      {
        "logicalAssetType": "reward.polaroid",
        "usage": "collectible-memory",
        "notes": "Optional collectible card tied to validated hangout milestones or advanced rewards."
      },
      {
        "logicalAssetType": "reward.video-call",
        "usage": "mission-reward",
        "notes": "Optional video-call reward clip; required only for reward-bearing advanced mission paths."
      }
    ],
    "runtimeAssumptions": [
      "Every playable city/map pin resolves through packages/contracts/world-map-registry.sample.json before selecting a roster.",
      "Each live mapLocationId references one starter slot roster via its dagLocationSlot and may reuse the same two-character roster across multiple pins in the same city.",
      "Cities may define reserved shared-slot rosters with no current live map pin yet, but those reserved rosters must not be treated as live map coverage.",
      "Tong remains a global assistant and is not counted toward the two local starter characters per slot.",
      "If optional outputs are missing, runtime-assets falls back to portrait.default + scene.default without blocking pack approval."
    ]
  },
