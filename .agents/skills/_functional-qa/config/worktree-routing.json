    "owner": "erniesg",
    "owner_type": "user",
    "number": 3,
    "lane_field": "Lane",
    "execution_mode_field": "Execution Mode",
    "portable_context_field": "Portable Context",
    "agent_ready_field": "Agent Ready",
    "blocked_by_field": "Blocked By",
