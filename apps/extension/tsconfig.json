{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "paths": {
      "@tong/core": ["./src/lib/core/index.ts"],
      "@tong/core/*": ["./src/lib/core/*"],
      "@tong/subtitles": ["./src/lib/subtitles/index.ts"],
      "@tong/subtitles/*": ["./src/lib/subtitles/*"],
      "@tong/romanization": ["./src/lib/romanization/index.ts"],
      "@tong/romanization/*": ["./src/lib/romanization/*"],
      "@tong/cjk-data": ["./src/lib/cjk-data/index.ts"],
      "@tong/cjk-data/*": ["./src/lib/cjk-data/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
